# ─────────────────────────────────────────────────────────────
# YouTube Music Streaming API — Environment Variables
# 1. Copy:  cp .env.example .env
# 2. Fill in your values below
# 3. Or use Admin Dashboard → Cloudinary / OAuth Setup to fill
# ─────────────────────────────────────────────────────────────

# ── Google OAuth (required for YouTube access) ────────────────
# Get from https://console.cloud.google.com/apis/credentials
# Type: "TV and Limited Input devices"
# Or import via: Admin → OAuth Setup → Import JSON
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# ── Cloudinary (required for audio storage) ──────────────────
# Get from https://cloudinary.com/console
# Or add via: Admin → Cloudinary → Add Account
CLOUDINARY_ACCOUNTS_JSON=[]

# ── Admin Dashboard ───────────────────────────────────────────
# Strong random string for signing session cookies
SESSION_SECRET=change-me-to-a-long-random-secret

# ── API Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# ── YouTube crawler ───────────────────────────────────────────
YOUTUBE_BASE_URL=https://www.youtube.com/results
YOUTUBE_TIMEOUT=30

# ── Redis cache (optional) ────────────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=3
REDIS_PASSWORD=
REDIS_TTL_SECONDS=3600

# ── Logging ───────────────────────────────────────────────────
LOG_DIR=logs
LOG_FILE_ENABLED=true
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# ── Audio download ────────────────────────────────────────────
DOWNLOAD_DIR=/tmp/youtube_audio
DOWNLOAD_BASE_URL=http://localhost:8000/downloads
DOWNLOAD_TIMEOUT=300
MAX_VIDEO_DURATION=600
AUDIO_BITRATE=128
CACHE_TTL_HOURS=24

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DOWNLOAD_PER_HOUR=20
RATE_LIMIT_STATIC_PER_MINUTE=60

# ── Feature flags ─────────────────────────────────────────────
ENABLE_CACHE=true
ENABLE_LOGGING=true
